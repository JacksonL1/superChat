# SGLang
SGLANG_BASE_URL=http://localhost:30000/v1
# 留空则自动取第一个可用模型
SGLANG_MODEL=default
# 需要鉴权的网关请填写（优先使用 SGLANG_API_KEY）
SGLANG_API_KEY=
# 兼容 ModelScope Token（未设置 SGLANG_API_KEY 时自动使用）
MODELSCOPE_API_TOKEN=

# Skills
SKILLS_DIR=./skills

# SQLite
DB_PATH=./data/superchat.db

# Agent
MAX_TOOL_ROUNDS=15
MAX_HISTORY_MESSAGES=40
